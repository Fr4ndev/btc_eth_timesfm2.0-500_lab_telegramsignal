"""
app/model.py - Compatible con tu instalación actual (TimesFM 2.5 style)
"""
import logging
from typing import Optional, Any
import torch

logger = logging.getLogger(__name__)

_model: Optional[Any] = None
_model_loaded: bool = False
_device_info: str = "unloaded"

def load_model(settings):
    global _model, _model_loaded, _device_info

    logger.info("Cargando TimesFM (CPU mode)...")

    try:
        import timesfm

        torch.set_float32_matmul_precision("high")

        # Usamos la única clase que tienes disponible
        model = timesfm.TimesFM_2p5_200M_torch.from_pretrained(
            "google/timesfm-2.0-500m-pytorch",   # intentamos cargar el checkpoint 2.0
            torch_compile=False,                 # pon True más tarde si quieres
        )

        # Compilación (opcional)
        try:
            model.compile()
            logger.info("Model compiled")
        except Exception as comp_e:
            logger.warning("Compile skipped: %s", comp_e)

        _model = model
        _model_loaded = True
        _device_info = "cpu"

        logger.info("✅ TimesFM cargado correctamente en CPU")
        return True

    except Exception as e:
        logger.error("Error cargando TimesFM: %s", str(e), exc_info=True)
        raise

def get_model() -> Any:
    if not _model_loaded or _model is None:
        raise RuntimeError("Modelo no cargado. Revisa los logs.")
    return _model

def get_device_info() -> str:
    return _device_info

def is_loaded() -> bool:
    return _model_loaded
